# Operations Mode
SIMULATION_MODE=False

# Sentinel Hub API Credentials
SENTINEL_HUB_CLIENT_ID=your_sentinel_hub_client_id
SENTINEL_HUB_CLIENT_SECRET=your_sentinel_hub_client_secret

# Planet API Key
PLANET_API_KEY=your_planet_api_key

# Global Forest Watch (GFW) API Key
GFW_API_KEY=your_gfw_api_key

# Gemini API Key (for LLM reasoning agent)
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
